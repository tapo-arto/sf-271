# SafetyFlash ympäristöasetukset
# Kopioi tämä tiedosto nimellä .env ja täytä arvot

APP_BASE_URL=https://example.com/safetyflash-system
APP_DEBUG=false

DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=
# ============================================================
# EMBED TOKEN SECRET
# ============================================================
# Generate with: openssl rand -hex 32
EMBED_SECRET=changeme-generate-with-openssl-rand-hex-32

# Optional: multiple keys for rotation (JSON format)
# EMBED_KEYS_JSON={"v1":"secret1","v2":"secret2"}

